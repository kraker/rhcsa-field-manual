# -*- mode: ruby -*-
# vi: set ft=ruby :

# Dev VM for The RHCSA Field Manual: RHEL 10 with Quarto + R + knitr
# for rendering the book's executable shell snippets.
#
# Quick start:
#   cp .rhel-credentials.template .rhel-credentials   # add RH dev creds
#   ./up.sh
#   vagrant ssh-config >> ~/.ssh/config               # for VS Code Remote SSH
Vagrant.configure("2") do |config|
  config.ssh.key_type = "ecdsa256"

  config.vm.box      = "kraker/rhel-10"
  config.vm.hostname = "rhcsa-dev"
  config.vm.network "private_network", ip: "192.168.56.20"

  # No synced folder: the kraker/rhel-10 box has no VirtualBox Guest
  # Additions, so the default vboxsf mount fails. Clone the repo
  # inside the VM over SSH instead.
  config.vm.synced_folder ".", "/vagrant", disabled: true

  # auto_attach must be false: RHEL 10 dropped `subscription-manager
  # --auto-attach` in favor of Simple Content Access, but the plugin
  # (v1.3.4) still passes the flag by default and registration fails.
  config.registration.username           = ENV["RHSM_USERNAME"]
  config.registration.password           = ENV["RHSM_PASSWORD"]
  config.registration.auto_attach        = false
  config.registration.unregister_on_halt = false

  config.vm.provider "virtualbox" do |vb|
    vb.name   = "rhcsa-dev"
    vb.memory = "4096"
    vb.cpus   = 2
  end

  config.vm.provision "shell", path: "provision.sh"
end
