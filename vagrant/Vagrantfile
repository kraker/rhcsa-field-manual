# -*- mode: ruby -*-
# vi: set ft=ruby :

# Development environment for The RHCSA Field Manual.
#
# A single RHEL 10 VM that runs the book's executable shell snippets
# through Quarto + knitr. Use VS Code's Remote SSH extension to connect
# and edit files under /home/vagrant/rhcsa-field-manual (the synced
# project root).
#
# Quick start:
#   cp .rhel-credentials.template .rhel-credentials   # add RH dev creds
#   ./up.sh
#   vagrant ssh-config >> ~/.ssh/config               # for VS Code Remote SSH
#
# Uses kraker/rhel-10, the box published to HCP Vagrant Registry by the
# sibling project at https://github.com/kraker/vagrant-rhel-boxes — same
# osbuild blueprint, same provider artifacts. The box ships unregistered;
# the vagrant-registration plugin attaches it to the user's RHSM
# subscription at first boot using the credentials in .rhel-credentials.
Vagrant.configure("2") do |config|
  config.ssh.key_type = "ecdsa256"

  # https://app.vagrantup.com/kraker/boxes/rhel-10
  config.vm.box      = "kraker/rhel-10"
  config.vm.hostname = "rhcsa-dev"

  # Static IP. Offset from the lab boxes in ../rhcsa/vagrant
  # (192.168.56.10/.11) so both setups can run side by side.
  config.vm.network "private_network", ip: "192.168.56.20"

  # Default `/vagrant` would map this `vagrant/` directory; remap to
  # the project root so the book lives at a clean, predictable path.
  config.vm.synced_folder ".", "/vagrant", disabled: true
  config.vm.synced_folder "..", "/home/vagrant/rhcsa-field-manual"

  # vagrant-registration: register the VM with RHSM at first boot using
  # the credentials sourced from .rhel-credentials by ./up.sh.
  config.registration.username           = ENV["RHSM_USERNAME"]
  config.registration.password           = ENV["RHSM_PASSWORD"]
  config.registration.unregister_on_halt = false

  config.vm.provider "virtualbox" do |vb|
    vb.name   = "rhcsa-dev"
    vb.memory = "4096"  # 4 GB — R + Quarto can be hungry during render
    vb.cpus   = 2
  end

  config.vm.provision "shell", path: "provision.sh"
end
